<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">

  <!-- Right click desktop menu -->
  <menu id="root-menu" label="AETHER OS">
    <item label="⬡  AETHER Launcher">
      <action name="Execute">
        <command>python3 /home/aether/.config/aether/aether_launcher.py</command>
      </action>
    </item>
    <separator/>
    <item label="⌨  Terminal">
      <action name="Execute"><command>xfce4-terminal</command></action>
    </item>
    <item label="◫  File Manager">
      <action name="Execute"><command>thunar</command></action>
    </item>
    <item label="◉  Browser">
      <action name="Execute"><command>firefox</command></action>
    </item>
    <separator/>
    <item label="◎  Settings">
      <action name="Execute"><command>xfce4-settings-manager</command></action>
    </item>
    <item label="◈  AETHER Web UI">
      <action name="Execute"><command>firefox http://localhost:8080</command></action>
    </item>
    <separator/>
    <menu id="client-list-combined-menu" label="⬚  Windows"/>
    <separator/>
    <item label="↺  Restart AETHER Bar">
      <action name="Execute">
        <command>bash -c "pkill -f aether_bar; sleep 1; python3 /home/aether/.config/aether/aether_bar.py &amp;"</command>
      </action>
    </item>
    <item label="↺  Restart Openbox">
      <action name="Reconfigure"/>
    </item>
    <separator/>
    <item label="⏻  Logout">
      <action name="Execute"><command>xfce4-session-logout</command></action>
    </item>
    <item label="⏻  Reboot">
      <action name="Execute"><command>sudo reboot</command></action>
    </item>
    <item label="⏻  Shutdown">
      <action name="Execute"><command>sudo poweroff</command></action>
    </item>
  </menu>

  <!-- Window context menu -->
  <menu id="client-menu" label="Window">
    <item label="Minimize">
      <action name="Iconify"/>
    </item>
    <item label="Maximize">
      <action name="ToggleMaximize"/>
    </item>
    <item label="Fullscreen">
      <action name="ToggleFullscreen"/>
    </item>
    <separator/>
    <item label="Snap Left">
      <action name="MoveResizeTo">
        <x>0</x><y>0</y><width>50%</width><height>100%</height>
      </action>
    </item>
    <item label="Snap Right">
      <action name="MoveResizeTo">
        <x>-0</x><y>0</y><width>50%</width><height>100%</height>
      </action>
    </item>
    <separator/>
    <item label="Close">
      <action name="Close"/>
    </item>
  </menu>

  <menu id="client-list-combined-menu"/>
</openbox_menu>
