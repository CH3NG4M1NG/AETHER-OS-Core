{
  "name": "discord-ai-bot",
  "version": "1.0.0",
  "description": "Discord AI bot with puter.js integration - no API key required",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
